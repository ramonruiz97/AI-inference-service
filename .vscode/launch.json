{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI (Uvicorn, reload, debug children)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--host", "127.0.0.1",
        "--port", "8000",
        "--reload-dir", "app"
      ],
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "subProcess": true
    }
  ]
}